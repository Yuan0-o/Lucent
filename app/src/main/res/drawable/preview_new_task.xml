<?xml version="1.0" encoding="utf-8"?>
<!-- Picker preview: a miniature of the real widget, so the picker never shows the app icon. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@drawable/widget_card_gradient" />
    <item android:gravity="center" android:width="64dp" android:height="64dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_chip" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item android:gravity="center" android:width="34dp" android:height="34dp"
        android:drawable="@drawable/ic_widget_task" />
    <item android:gravity="bottom|center_horizontal" android:bottom="14dp"
        android:width="44dp" android:height="7dp">
        <shape android:shape="rectangle">
            <solid android:color="#B8FFFFFF" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</layer-list>
