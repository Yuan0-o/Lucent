<?xml version="1.0" encoding="utf-8"?>
<!-- Task-summary widget (task 9). Refreshes on a periodic schedule (the system clamps this to a
     ~30-minute minimum) and also whenever it's added or resized. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="80dp"
    android:minResizeWidth="80dp"
    android:minResizeHeight="40dp"
    android:targetCellWidth="2"
    android:targetCellHeight="1"
    android:updatePeriodMillis="1800000"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:previewLayout="@layout/widget_task_summary"
    android:initialLayout="@layout/widget_task_summary" />
