<?xml version="1.0" encoding="utf-8"?>
<!-- The scrollable tasks list. Resizable both ways; refreshes every 30 min as a backstop on top of
     the explicit refresh the app fires after a task changes. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="180dp"
    android:minHeight="110dp"
    android:targetCellWidth="3"
    android:targetCellHeight="3"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/widget_today_tasks"
    android:previewLayout="@layout/widget_today_tasks"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen" />
