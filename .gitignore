# Build outputs and local tool state.
build/
.gradle/
local.properties
*.iml
.idea/
__pycache__/

# Native sources fetched by CI at build time (see .github/workflows/build.yml).
app/src/main/cpp/llama.cpp-src/
rust/target/

# Signing material. The release keystore lives in a GitHub Actions secret and in your own
# backup, never here. This is a safety net for git clients; GitHub's *web* uploader does not
# read .gitignore, so the real rule is: never select these files when uploading.
*.keystore
*.jks
keystore-base64.txt
